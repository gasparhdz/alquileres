// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTENTICACIÓN Y USUARIOS
// ============================================

model Usuario {
  id            String    @id @default(uuid())
  nombre        String
  email         String    @unique
  passwordHash  String    @map("password_hash")
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  roles         UsuarioRol[]

  @@map("usuarios")
}

model Rol {
  id          String      @id @default(uuid())
  nombre      String      @unique
  descripcion String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  usuarios    UsuarioRol[]

  @@map("roles")
}

model UsuarioRol {
  usuarioId  String   @map("usuario_id")
  rolId      String   @map("rol_id")
  createdAt  DateTime @default(now()) @map("created_at")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  rol        Rol      @relation(fields: [rolId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuario_rol")
}

// ============================================
// CATÁLOGOS Y PARÁMETROS
// ============================================

model Categoria {
  id          String      @id @default(uuid())
  codigo      String      @unique
  descripcion String
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  
  parametros  Parametro[]

  @@map("categorias")
}

model Parametro {
  id          String      @id @default(uuid())
  categoriaId String      @map("categoria_id")
  codigo      String
  descripcion String
  abreviatura String?
  activo      Boolean     @default(true)
  orden       Int         @default(0)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  categoria   Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([categoriaId, codigo])
  @@map("parametros")
}

// ============================================
// ENTIDADES PRINCIPALES
// ============================================

model Inquilino {
  id            String      @id @default(uuid())
  apellido      String?
  nombre        String?
  razonSocial   String?     @map("razon_social")
  dni           String?
  cuit          String?
  mail          String?
  telefono      String?
  direccion     String?
  localidad     String?
  condicionIva  String?     @map("condicion_iva")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  isDeleted     Boolean     @default(false) @map("is_deleted")

  contratos     Contrato[]

  @@unique([dni, nombre], name: "unique_dni_nombre")
  @@unique([cuit], name: "unique_cuit_inquilino")
  @@map("inquilinos")
}

model Propietario {
  id            String      @id @default(uuid())
  apellido      String?
  nombre        String?
  razonSocial   String?     @map("razon_social")
  dni           String?
  cuit          String?
  mail          String?
  telefono      String?
  direccion     String?
  localidad     String?
  condicionIva  String?     @map("condicion_iva")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  isDeleted     Boolean     @default(false) @map("is_deleted")

  unidades      Unidad[]

  @@unique([dni, nombre], name: "unique_dni_nombre_prop")
  @@unique([cuit], name: "unique_cuit_propietario")
  @@map("propietarios")
}

model Unidad {
  id            String              @id @default(uuid())
  propietarioId String              @map("propietario_id")
  direccion     String
  localidad     String
  tipo          String?             // Parametro categoria: tipo_unidad
  estado        String?             // Parametro categoria: estado_unidad
  codigoInterno String?             @map("codigo_interno")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")
  isDeleted     Boolean             @default(false) @map("is_deleted")

  propietario   Propietario         @relation(fields: [propietarioId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cuentas       CuentaTributaria[]
  contratos     Contrato[]
  liquidaciones Liquidacion[]

  @@unique([propietarioId, direccion, localidad], name: "unique_unidad")
  @@map("unidades")
}

model CuentaTributaria {
  id            String      @id @default(uuid())
  unidadId      String      @map("unidad_id")
  tipoImpuesto  String      @map("tipo_impuesto") // Parametro categoria: tipo_impuesto
  codigo1       String?     @map("codigo_1")
  codigo2       String?     @map("codigo_2")
  periodicidad  String?     // Parametro categoria: periodicidad
  observaciones String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  isDeleted     Boolean     @default(false) @map("is_deleted")

  unidad        Unidad      @relation(fields: [unidadId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items         LiquidacionItem[]

  @@unique([unidadId, tipoImpuesto], name: "unique_cuenta_tributaria")
  @@map("cuentas_tributarias")
}

model Contrato {
  id                    String                  @id @default(uuid())
  unidadId              String                  @map("unidad_id")
  inquilinoId           String                  @map("inquilino_id")
  nroContrato           String?                 @map("nro_contrato")
  fechaInicio           DateTime                @map("fecha_inicio")
  fechaFin              DateTime?               @map("fecha_fin")
  duracionMeses         Int?                    @map("duracion_meses")
  montoInicial          Decimal                 @map("monto_inicial") @db.Decimal(10, 2)
  gastosAdministrativos Decimal?                @map("gastos_administrativos") @db.Decimal(10, 2)
  metodoAjuste          String?                 @map("metodo_ajuste") // Parametro categoria: metodo_ajuste
  frecuenciaAjusteMeses Int?                    @map("frecuencia_ajuste_meses")
  topeAjuste            Decimal?                @map("tope_ajuste") @db.Decimal(5, 2)
  registradoAfip        Boolean                 @default(false) @map("registrado_afip")
  moneda                String?                 @default("ARS") // Parametro categoria: moneda
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  deletedAt             DateTime?               @map("deleted_at")
  isDeleted             Boolean                 @default(false) @map("is_deleted")

  unidad                Unidad                  @relation(fields: [unidadId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  inquilino             Inquilino               @relation(fields: [inquilinoId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  responsabilidades     ContratoResponsabilidad[]
  garantias             Garantia[]
  gastosIniciales       ContratoGastoInicial[]
  liquidaciones         Liquidacion[]

  @@unique([unidadId, inquilinoId, fechaInicio], name: "unique_contrato")
  @@map("contratos")
}

model ContratoResponsabilidad {
  id          String      @id @default(uuid())
  contratoId  String      @map("contrato_id")
  tipoCargo   String      @map("tipo_cargo") // Parametro categoria: tipo_cargo
  quienPaga   String      @map("quien_paga") // Parametro categoria: quien_paga (inquilino/propietario/prorrata)
  titular     String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  contrato    Contrato    @relation(fields: [contratoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("contrato_responsabilidades")
}

model Garantia {
  id            String      @id @default(uuid())
  contratoId    String      @map("contrato_id")
  tipoGarantia  String?     @map("tipo_garantia") // Parametro categoria: tipo_garantia
  estadoGarantia String?    @map("estado_garantia") // Parametro categoria: estado_garantia
  apellido      String?
  nombre        String?
  dni           String?
  cuit          String?
  telefono      String?
  mail          String?
  direccion     String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  contrato      Contrato    @relation(fields: [contratoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("garantias")
}

model ContratoGastoInicial {
  id              String      @id @default(uuid())
  contratoId      String      @map("contrato_id")
  tipoGastoInicial String     @map("tipo_gasto_inicial") // Parametro categoria: tipo_gasto_inicial
  importe         Decimal     @db.Decimal(10, 2)
  estado          String?     // Parametro categoria: estado_gasto
  observaciones   String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  contrato        Contrato    @relation(fields: [contratoId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@map("contrato_gastos_iniciales")
}

model Liquidacion {
  id          String            @id @default(uuid())
  contratoId  String            @map("contrato_id")
  unidadId    String            @map("unidad_id")
  periodo     String            // Formato: YYYY-MM
  estado      String            @default("borrador") // Parametro categoria: estado_liquidacion
  vencimiento DateTime?
  total       Decimal           @db.Decimal(10, 2)
  numeracion  String?
  observaciones String?
  emisionAt   DateTime?         @map("emision_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  contrato    Contrato          @relation(fields: [contratoId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  unidad      Unidad            @relation(fields: [unidadId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  items       LiquidacionItem[]

  @@unique([contratoId, periodo], name: "unique_liquidacion")
  @@map("liquidaciones")
}

model LiquidacionItem {
  id                  String            @id @default(uuid())
  liquidacionId       String            @map("liquidacion_id")
  tipoCargo           String            @map("tipo_cargo") // Parametro categoria: tipo_cargo
  cuentaTributariaId  String?           @map("cuenta_tributaria_id")
  periodoRef          String?           @map("periodo_ref")
  importe             Decimal           @db.Decimal(10, 2)
  quienPaga           String            @map("quien_paga") // Parametro categoria: quien_paga
  fuente              String?           // Parametro categoria: fuente (manual/automatico)
  refExterna          String?           @map("ref_externa")
  observaciones       String?
  orden               Int               @default(0)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  liquidacion         Liquidacion       @relation(fields: [liquidacionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cuentaTributaria    CuentaTributaria? @relation(fields: [cuentaTributariaId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("liquidacion_items")
}

